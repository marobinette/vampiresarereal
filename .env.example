# Copy to .env and fill in. .env is gitignored — never commit real credentials.
# On Vercel, set these same keys under Project → Settings → Environment Variables.
#
# The landing page is fully static and needs NONE of these. They are only used
# once content is served from DynamoDB (see src/lib/server/dynamo.js).

# AWS region your DynamoDB table lives in (e.g. us-east-1)
AWS_REGION=us-east-1

# IAM user credentials scoped to the vampire_project table (see README)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB table name (defaults to "vampire_project" if unset)
VAMPIRE_TABLE=vampire_project

# Shared secret for future write operations (add/edit/delete articles).
# Generate a long random string, e.g.:  openssl rand -hex 32
ADMIN_TOKEN=
